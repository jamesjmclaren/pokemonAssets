# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Poketrace API (unified card + sealed pricing)
POKETRACE_API_KEY=your_poketrace_api_key

# Admin User IDs (comma-separated Clerk user IDs for admin access)
ADMIN_USER_IDS=clerk_user_id_1,clerk_user_id_2

# Stripe (payment processing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Maileroo (transactional emails)
MAILEROO_API_KEY=your_maileroo_api_key
MAILEROO_DOMAIN=west.investments

